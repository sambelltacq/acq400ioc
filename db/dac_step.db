# dac_step: write a pre-programmed DAC value every tick (~20Hz).

# STEP:${CH} is the DAC output pattern per step for ${CH}
record(waveform, "${UUT}:${SITE}:AO:STEP:${CH}") {
        field(DTYP, "Soft Channel")
        field(FTVL, "FLOAT")
        field(NELM, "${size}")
}


record(bi, "${UUT}:${SITE}:AO:HAS_STEP") {
        field(VAL,  "1")
}
# BQ "Buffer Queue" hooks end of buffer (DMA DONE) notification aka Burst Complete
# I/O Intr drives entire processing tree.
record(longin, "${UUT}:0:BQ") {
        field(DTYP, "stream")
        field(INP, "@dac_step.proto getBQ ${BQS}")
        field(SCAN, "I/O Intr")
        field(FLNK, "${UUT}:0:AO:STEP:CURSOR:c")
}

# CURSOR:c : increments CURSOR between limits.
# the limit is set separately in dac_step1.db to be the FIRST STEP channel
record(calcout, "${UUT}:0:AO:STEP:CURSOR:c") {
        field(DTYP, "Soft Channel")
        field(INPA, "${UUT}:0:AO:STEP:CURSOR")
#        field(INPB, "${UUT}:${SITE}:AO:STEP:${CH}.NORD")
        field(CALC, "A<B? A+1: A")
        field(OUT,  "${UUT}:0:AO:STEP:CURSOR PP")
}

# CURSOR : indexes STEP:${CH} scan output pattern
record(longout, "${UUT}:0:AO:STEP:CURSOR") {
        field(DTYP, "Soft Channel")
        field(DRVL, "0")
        field(DRVH, "250000")
        field(FLNK, "${UUT}:0:AO:STEP:f0")
}

# STEP:${CH}:i returns current STEP value from array indexed by CURSOR
record(subArray, "${UUT}:${SITE}:AO:STEP:${CH}:i") {
        field(DTYP, "Soft Channel")
        field(FTVL, "FLOAT")
        field(INP,  "${UUT}:${SITE}:AO:STEP:${CH}")
        field(MALM, "${size}")
        field(NELM, "1")
        field(FLNK, "${UUT}:${SITE}:AO:STEP:${CH}:w")
}

record(bo, "${UUT}:${SITE}:AO:STEP:${CH}:EN"){
        field(DTYP, "Soft Channel")
        field(ZNAM, "0")
        field(ONAM, "1")
        field(VAL, "0")
        field(PINI, "YES")
}

# STEP:${CH}:w writes the value to the SLOW_SET actuator
record(ao, "${UUT}:${SITE}:AO:STEP:${CH}:w") {
        field(DTYP, "Soft Channel")
        field(DOL,  "${UUT}:${SITE}:AO:STEP:${CH}:i")
        field(OMSL, "closed_loop")
        field(OUT,  "${UUT}:${SITE}:AO:SLOW_SET:CH:${CH} PP")
        field(DISV, "0")
        field(SDIS, "${UUT}:${SITE}:AO:STEP:${CH}:EN")
}

# ${UUT}:0:AO:STEP:f0 :: connects CURSOR to potentially multiple sites
record(fanout, "${UUT}:0:AO:STEP:f0") {
        field(LNK${SITE}, "${UUT}:${SITE}:AO:STEP:f1")
}

# ${SITE}:AO:STEP:f1 connects update to individual channels (max:8)
record(dfanout, "${UUT}:${SITE}:AO:STEP:f1") {
       field(DOL, "${UUT}:0:AO:STEP:CURSOR")
       field(OMSL, "closed_loop")
       field(OUT${CHA}, "${UUT}:${SITE}:AO:STEP:${CH}:i.INDX PP")   
}

