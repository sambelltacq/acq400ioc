# ACQ426ERM

record (mbbo, "${UUT}:${SITE}:GAIN:${CH}") {	
	field(DTYP, "Soft Channel")
        field(NOBT, "4")        
        field(ZRST, "+/-10V")
        field(ONST, "+/-5V")
        field(TWST, "+/-2V5")
        field(THST, "0-10V")
        field(FRST, "0-5V")
        field(FVST, "0-12V5")
        field(SXST, "+/-12V5")
        field(SVST, "0-20V")
        field(EIST, "+/-20V")
        field(NIST, "0-25V")
        field(TEST, "+/-25V")
        field(ELST, "0-40V")
        field(TVST, "+/-40V")
        field(TTST, "")
        field(FTST, "")
        field(FFST, "")
	field(VAL,  "0")
        field(DISV, "1")
        field(SDIS, "${UUT}:${SITE}:ACTIVE")	
        field(FLNK, "${UUT}:${SITE}:GAIN:s")
}

record(waveform, "${UUT}:${SITE}:GAIN:${CH}:X") {
        field(DTYP, "Soft Channel")
        field(NELM, "${nchanp1}")
        field(FTVL, "UCHAR")
        field(DESC, "set gain per chan by ordinal")
}

record(calcout, "${UUT}:${SITE}:GAIN:${CH}:s") {
        field(CALC, "1")
        field(OOPT, "Every Time")
        field(DOPT, "Use CALC")
        field(OUT, "${UUT}:${SITE}:GAIN:RDIS PP")
        field(FLNK, "${UUT}:${SITE}:GAIN:fan1")
}

record(bo, "${UUT}:${SITE}:GAIN:RDIS") {
        field(DTYP, "Soft Channel")
        field(ZNAM, "ENABLE")
        field(ONAM, "DISABLE")
        field(DESC, "Global gain readback disable")
        field(PINI, "YES")
        field(VAL,  "1")
}

record(dfanout, "${UUT}:${SITE}:GAIN:fan1") {
	field(DOL,  "${UUT}:${SITE}:GAIN:${CH}")
	field(OMSL, "closed_loop")
	field(FLNK, "${UUT}:${SITE}:GAIN:fan2")
}

record(dfanout, "${UUT}:${SITE}:GAIN:fan2") {
	field(DOL,  "${UUT}:${SITE}:GAIN:${CH}")
	field(OMSL, "closed_loop")
	field(FLNK, "${UUT}:${SITE}:GAIN:fan3")
}

record(dfanout, "${UUT}:${SITE}:GAIN:fan3") {
	field(DOL,  "${UUT}:${SITE}:GAIN:${CH}")
	field(OMSL, "closed_loop")
	field(FLNK, "${UUT}:${SITE}:GAIN:fan4")
}
record(dfanout, "${UUT}:${SITE}:GAIN:fan4") {
	field(DOL,  "${UUT}:${SITE}:GAIN:${CH}")
	field(OMSL, "closed_loop")
	field(FLNK, "${UUT}:${SITE}:GAIN_CHANGES")
}

record (calc, "${UUT}:${SITE}:GAIN_CHANGES") {
	field(INPA, "${UUT}:${SITE}:GAIN_CHANGES")
	field(CALC, "A+1")
}