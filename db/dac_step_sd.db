# dac_step for StreamDevice ${port} is an drvAsynIPPort
# BQ "Buffer Queue" hooks end of buffer (DMA DONE) notification aka Burst Complete
# I/O Intr drives entire processing tree.
record(longin, "${UUT}:0:BQ") {
        field(DTYP, "stream")
        field(INP, "@dac_step.proto getBQ ${port}")
        field(SCAN, "I/O Intr")
        field(FLNK, "${UUT}:0:AO:STEP:CURSOR:c")
}