
# by convention, there's ALWAYS a TB in site 1 
# True 80% of the time, and may as well be there always

record(aSub, "${UUT}:1:AI:TW:TB") {
	field(SNAM, "timebase")
	
	field(FTA,  "LONG")
	field(NOA,  "1")
	field(INPA, "${UUT}:MODE:TRANSIENT:PRE")
	
	field(FTB,  "LONG")
	field(NOB,  "1")
	field(INPB, "${UUT}:MODE:TRANSIENT:POST")
	
	field(FTC,  "FLOAT")
	field(NOC,  "1")
	field(INPC,  "${UUT}:1:DT")
	
	field(FTVA, "FLOAT")
	field(NOVA, "${size}")
	field(DESC, "AI waveform record scaled to volts")	
}	