# event selection
# SRC_SEL  EVENT0:DX   EVENT_SRC:0     
# EXT           0           0  (EXT)
# ATD_RAW       0           3  (MOD)
# ATD_GRP       1           x 
record(mbbo, "${UUT}:${SITE}:ANATRG:SRC_SEL")   {
        field(DTYP, "Soft Channel")
        field(NOBT, "2")        
        field(ZRST, "EXT")
        field(ONST, "ATD_RAW")
        field(TWST, "ATD_GRP")
        field(THST, "")
        field(FLNK, "${UUT}:${SITE}:ANATRG:SRC_SEL:c PP")
        field(DESC, "analog trigger mode")
        field(PINI, "YES")
}

record(calcout, "${UUT}:${SITE}:ANATRG:SRC_SEL:c") {
        field(INPA, "${UUT}:${SITE}:ANATRG:SRC_SEL")
        field(CALC, "A != 0 ? 3: 0")
        field(OCAL, "A == 2")
        field(OOPT, "Every Time")
        field(DOPT, "Use OCAL")
        field(OUT,  "${UUT}:${SITE}:EVENT0:DX PP")
        field(FLNK, "${UUT}:0:SIG:EVENT_SRC:0:atd PP")
}

record (mbbo, "${UUT}:0:SIG:EVENT_SRC:0:atd") {
        field(DTYP, "Soft Channel")
        field(NOBT, "2")
        field(ZRST, "TRG")
        field(ONST, "")
        field(TWST, "")
        field(THST, "MOD")
        field(DOL,  "${UUT}:${SITE}:ANATRG:SRC_SEL:c")
        field(OMSL, "closed_loop")
        field(OUT,  "${UUT}:0:SIG:EVENT_SRC:0 PP")
}

record(bo, "${UUT}:${SITE}:ANATRG:GROUP_MODE") {
        field(DTYP, "stream")
        field(OUT, "@anatrg.proto set_group_status_mode ${SPORT}")
        #            1234567890123456789012345678901234567890
        field(DESC, "CURRENT: trg if all members active NOW")
        field(ZNAM, "CURRENT")
        field(ONAM, "HISTORY")
}

record(longout, "${UUT}:${SITE}:ANATRG:GROUP:FIRST_N") {
        field(DTYP, "stream")
        field(OUT, "@anatrg.proto set_group_first_n ${SPORT}")
        field(DESC, "group trg if N mmbr active (0=ALL)")
        field(DRVL, "0")
        field(DRVH, "32")
        field(VAL,  "0")
        field(PINI, "YES")
}

