# event selection
# SRC_SEL  EVENT0:DX   EVENT_SRC:0     
# EXT           0           0  (EXT)
# ATD_RAW       0           3  (MOD)
# ATD_GRP       1           x 
record(mbbo, "${UUT}:${SITE}:ANATRG:SRC_SEL")   {
        field(DTYP, "Soft Channel")
        field(NOBT, "2")        
        field(ZRST, "EXT")
        field(ONST, "ATD_RAW")
        field(TWST, "ATD_GRP")
        field(THST, "")
        field(FLNK, "${UUT}:${SITE}:ANATRG:SRC_SEL:c PP")
        field(DESC, "analog trigger mode")
        field(PINI, "YES")
}

record(calcout, "${UUT}:${SITE}:ANATRG:SRC_SEL:c") {
        field(INPA, "${UUT}:${SITE}:ANATRG:SRC_SEL")
        field(CALC, "A != 0 ? 3: 0")
        field(OCAL, "A == 2")
        field(OOPT, "Every Time")
        field(DOPT, "Use OCAL")
        field(OUT,  "${UUT}:${SITE}:EVENT0:DX PP")
        field(FLNK, "${UUT}:0:SIG:EVENT_SRC:0:atd PP")
}

record (mbbo, "${UUT}:0:SIG:EVENT_SRC:0:atd") {
        field(DTYP, "Soft Channel")
        field(NOBT, "2")
        field(ZRST, "TRG")
        field(ONST, "")
        field(TWST, "")
        field(THST, "MOD")
        field(DOL,  "${UUT}:${SITE}:ANATRG:SRC_SEL:c")
        field(OMSL, "closed_loop")
        field(OUT,  "${UUT}:0:SIG:EVENT_SRC:0 PP")
}
