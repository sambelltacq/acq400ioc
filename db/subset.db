record(waveform, "${UUT}:0:STREAM_SUBSET_MASK") {
        field(DTYP, "Soft Channel")
        field(NELM, "${NCHAN}")
        field(FTVL, "UCHAR")
        field(DESC, "channel subset mask")
        field(FLNK, "${UUT}:0:STREAM_SUBSET_MASK:w PP")
}

record(stringout, "${UUT}:0:STREAM_SUBSET_MASK:fn") {
        field(DTYP, "Soft Channel")
        field(VAL,  "/etc/acq400/0/stream_subset_mask")
        field(PINI, "YES")
}

record(aSub, "${UUT}:0:STREAM_SUBSET_MASK:w") {
        field(SNAM, "bitmask")

        field(FTA,  "UCHAR")
        field(NOA,  "${NCHAN}")
        field(INPA, "${UUT}:0:STREAM_SUBSET_MASK")

        field(FTF, "STRING")
        field(NOF, "1")
        field(INPF, "${UUT}:0:STREAM_SUBSET_MASK:fn" )
}
