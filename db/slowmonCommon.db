# slowmonCommon.db :: slowmon key params

record(longout, "$(UUT):0:SLOWMON:SLOWMONMS") {
    field(DTYP, "asynInt32")
    field(OUT,  "@asyn($(PORT),0,$(TIMEOUT))SLOWMONMS") 
    field(DESC, "Set sample interval ms")
    field(EGU,  "ms")
    field(DRVH, "1000")
    field(DRVL, "1")
    field(PINI, "YES")
    field(VAL,  "1000")
}

record(longout, "$(UUT):0:SLOWMON:EN") {
    field(DTYP, "Soft Channel")
    field(DESC, "Set sample interval ms")
    field(DRVL, "0")
    field(DRVH, "1")
    field(PINI, "YES")
    field(VAL,  "0")
    field(FLNK, "$(UUT):0:SLOWMON:EN:c")
}

record(calc, "$(UUT):0:SLOWMON:EN:c") {
    field(INPA, "$(UUT):0:SLOWMON:EN")
    field(INPB, "${UUT}:MODE:TRANS_ACT:STATE")
    field(INPC, "${UUT}:MODE:CONTINUOUS:STATE")
    field(CALC, "A && (B==2||B==3||C==2)")
    field(FLNK, "$(UUT):0:SLOWMON:EN:w PP")
}

record(fanout, "${UUT}:MODE:CONTINUOUS:STATE_f") {
    field(FLNK, "$(UUT):0:SLOWMON:EN:c PP")
}

record(fanout, "${UUT}:MODE:TRANS_ACT:STATE_f") {
    field(LNK3, "$(UUT):0:SLOWMON:EN:c PP")
}
record(longout, "$(UUT):0:SLOWMON:EN:w") {
    field(DTYP, "asynInt32")
    field(OUT,  "@asyn($(PORT),0,$(TIMEOUT))MEAN_EN") 
    field(DESC, "Set sample interval ms")
    field(DOL,  "$(UUT):0:SLOWMON:EN:c")
    field(OMSL, "closed_loop")
    field(DRVL, "0")
    field(DRVH, "1")
    field(PINI, "YES")
    field(VAL,  "0")
}

record(longout, "$(UUT):0:SLOWMON:QESLO") {
    field(DTYP, "asynInt32")
    field(OUT,  "@asyn($(PORT),0,$(TIMEOUT))QESLO")
    field(DESC, "show 4 elements from ESLO on console")
    field(DRVL, "0")
    field(DRVH, "$(NCHAN)")
    field(PINI, "YES")
    field(VAL,  "0")
}

record(mbbo, "${UUT}:0:SLOWMON:WATERFALL") {
    field(DTYP, "asynInt32")
    field(OUT,  "@asyn($(PORT),0,$(TIMEOUT))WATERFALL")
    field(DESC, "offset traces on display")
    field(NOBT, "3")
    field(ZRVL, "0")
    field(ONVL, "1")
    field(TWVL, "2")
    field(THVL, "5")
    field(FRVL, "10")
    field(ZRST, "0")
    field(ONST, "1")
    field(TWST, "2")
    field(THST, "5")
    field(FRST, "10")    
    field(PINI, "YES")
    field(VAL,  "0")
}

record(longout, "$(UUT):0:SLOWMON:QEOFF") {
    field(DTYP, "asynInt32")
    field(OUT,  "@asyn($(PORT),0,$(TIMEOUT))QEOFF")
    field(DESC, "show 4 elements from EOFF on console")
    field(DRVL, "0")
    field(DRVH, "$(NCHAN)")
    field(PINI, "YES")
    field(VAL,  "0")
}

# make one
record(waveform, "$(UUT):0:SLOWMON:MEAN:RAW") {
    field(DTYP, "asynInt16ArrayIn")
    field(INP,  "@asyn($(PORT),0,$(TIMEOUT))MEAN_RAW")
    field(FTVL, "SHORT")            # @@todo
    field(NELM, "$(NCHAN)")
    #field(LOPR, "0")
    #field(HOPR, "10")
    field(EGU,  "codes")
    field(SCAN, "I/O Intr")
}

record(waveform, "$(UUT):0:SLOWMON:MEAN") {
    field(DTYP, "asynFloat32ArrayIn")
    field(INP,  "@asyn($(PORT),0,$(TIMEOUT))MEAN_EGU")
    field(FTVL, "FLOAT")
    field(NELM, "$(NCHAN)")
    #field(LOPR, "0")
    #field(HOPR, "10")
    field(EGU,  "V")
    field(SCAN, "I/O Intr")
    field(FLNK, "$(UUT):0:SLOWMON:f")
}

record(fanout, "$(UUT):0:SLOWMON:f") {
    field(SELM, "All")
}

